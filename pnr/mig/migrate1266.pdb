        flat_vpoly_touch_GCN { touchingexact(flat_vpoly_new,1,flat_GCN) }
        dummy_vpoly {
          dummy_vpoly_tmp|touchingexact(flat_vpoly_touch_GCN,0,flat_diff) }
        vpoly { vpoly&!dummy_vpoly }
      ]
      remove_layers [ flat_vpoly flat_GCN flat_diff dummy_vpoly_tmp
        flat_vpoly_new flat_vpoly_touch_GCN ]
    }
    turn_dummy_layers_to_real_layers {
      new_layers [
        topLevel_dummies { selectcell(_TOP_,dummy_vpoly) }
        dummy_vpoly { sh(dummy_vpoly&!topLevel_dummies) }
      ]
      rename_layers [
        vpoly { dummy_vpoly }
      ]
    }
    Update_vpolySR_big_size {
      new_layers [
        vpolySR_big { vpolySR_big-0.005x }
      ]
    }
    free_nwell {
      new_layers [
        nwell { sh(nwell|((nwell+0.005x)&!chkBoundary)) }
        nwell_flat { flattenlayer(nwell) }
        nwell_close_0.32_gaps_in_x { nwell_flat+0.16x-0.16x }
        nwell_hole { nwell_close_0.32_gaps_in_x&!nwell_flat }
        flat_diff { flattenlayer(ndiff|pdiff) }
        nwell_hole_touch_diff { touching(nwell_hole,flat_diff) }
        nwell { nwell|(nwell_hole&!nwell_hole_touch_diff) }
      ]
      remove_layers [ nwell_concave nwell_convex ]
    }
    remove_trans {
      remove_layers [ NTRAN PTRAN ]
    }
    create_NSDdiffSD_from_diffSD {
      new_layers [
        NSDdiffSD { touchingexact(diffSD,1,vpoly) }
      ]
    }
    create_metal1SD {
      new_layers [
        vert_m1 { sh(maxwidthx(minwidthx(metal1,0.08),0.08)) }
        metal1SD { sh(vert_m1&selectshape(POLYGONS,pdiff|ndiff)) }
      ]
      remove_layers [ vert_m1 ]
    }
    m1_p2p_create {
      new_layers [
        metal1 { poltopath(metal1) }
      ]
    }
    createFixedObjectsRectangles {
      new_layers [
        fixed_metal1_tmp { maxwidthx(minwidthx(flattenlayer(metal1),0.08),0.08) }
        fixed_metal1 {
          maxwidthx(minwidthx(fixed_metal1_tmp&(TCNgrid+0.035x),0.08),0.08) }
      ]
      remove_layers [ fixed_metal1_tmp fixed_metal1_flat vpolyrecT TCNrecT
        metal1rec metal1recT ]
    }
    markTopBorder {
      new_layers [
        topBorder { flattenlayer(chkBoundary) }
        chkBoundary { chkBoundary|topBorder }
        polygrid { polygrid&(topBorder+0.02x) }
        TCNgrid { TCNgrid&(topBorder+0.02x) }
      ]
    }
    settings {
      verbose { YES }
      path_type { FLUSH KEEPSAME }
      max_coordinates { 4000 }
      grid {
        global { 0.005 }
        x
        y
      }
      remove_empty_symbols { NO }
      poltopath_tolerance [ 0 0 ]
      scaling { YES }
      keep_path_connectivity { YES }
    }
    p2p_create {
      new_layers [
        metal1 { poltopath(metal1) }
        metal2 { poltopath(metal2) }
        metal3 { poltopath(metal3) }
        metal4 { poltopath(metal4) }
        metal5 { poltopath(metal5) }
        metal6 { poltopath(metal6) }
        metal7 { poltopath(metal7) }
        metal8 { poltopath(metal8) }
      ]
    }
    PathToPol {
      new_layers [
        metal1 { pathtopol(metal1) }
        metal2 { pathtopol(metal2) }
        metal3 { pathtopol(metal3) }
        metal4 { pathtopol(metal4) }
        metal5 { pathtopol(metal5) }
      ]
    }
    p2p_cleanup {
      new_layers [
        M1_SHORT { metal1_short_path }
        M2_SHORT { metal2_short_path }
        M3_SHORT { metal3_short_path }
        M4_SHORT { metal4_short_path }
        M5_SHORT { metal5_short_path }
        metal1_short_path { pathtopol(metal1_short_path) }
        metal2_short_path { pathtopol(metal2_short_path) }
        metal3_short_path { pathtopol(metal3_short_path) }
        metal4_short_path { pathtopol(metal4_short_path) }
        metal5_short_path { pathtopol(metal5_short_path) }
      ]
      rename_layers [
        metal1 { metal1_short_path }
        metal2 { metal2_short_path }
        metal3 { metal3_short_path }
        metal4 { metal4_short_path }
        metal5 { metal5_short_path }
      ]
      remove_layers [ GCN_DBGLvsTxt M1_SHORT M2_SHORT M3_SHORT M4_SHORT
        M5_SHORT TCN_DBGLvsTxt contact_up_1L metal1_DBGLvsTxt metal1_up_1L
        metal2_DBGLvsTxt metal2_portDrawing_DBGLvsTxt metal2_portDrawing_TmpLvs
        metal3_DBGLvsTxt metal3_portDrawing_DBGLvsTxt metal3_portDrawing_TmpLvs
        metal4_DBGLvsTxt metal4_portDrawing_TmpLvs nwell_DBGLvsTxt
        ndiff_portDrawing_DBGLvsTxt ndiff_portDrawing_TmpLvs
        pdiff_portDrawing_DBGLvsTxt pdiff_portDrawing_TmpLvs poly_up_1L
        vpoly_DBGLvsTxt ]
    }
  }
  pass1 {
    process {
      layers {
        m1_edge {
          mode [ FREE ]
        }
        vpoly {
          mode [ FREE ]
        }
        TCN {
          mode [ FREE ]
        }
        fixed_metal1 {
          mode [ FREE ]
        }
      }
    }
    compaction {
      passes {
        firstpass [ Y ]
        nr [ 1 ]
        last [ NO ]
      }
    }
  }
  pass2 {
    process {
      layers {
        m1_edge {
          mode [ FIXED ]
        }
        vpoly {
          mode [ FIXED ]
        }
        TCN {
          mode [ FIXED ]
        }
        fixed_metal1 {
          mode [ FIXED ]
        }
        tap {
          mode [ FIXED ]
        }
      }
    }
    compaction {
      passes {
        nr [ 1 ]
        current [ 2 ]
        last [ NO ]
      }
    }
  }
  pass3 {
    process {
      layers {
        m1_edge {
          mode [ FREE ]
        }
        vpoly {
          mode [ FREE ]
        }
        TCN {
          mode [ FREE ]
        }
        fixed_metal1 {
          mode [ FREE ]
        }
        tap {
          mode [ FREE ]
        }
      }
    }
    compaction {
      passes {
        nr [ 1 ]
        current [ 3 ]
        last [ NO ]
      }
    }
  }
  pass4 {
    process {
      layers {
        m1_edge {
          mode [ FIXED ]
        }
        vpoly {
          mode [ FIXED ]
        }
        TCN {
          mode [ FIXED ]
        }
        fixed_metal1 {
          mode [ FIXED ]
        }
        tap {
          mode [ FIXED ]
        }
      }
    }
    compaction {
      passes {
        nr [ 1 ]
        current [ 4 ]
        last [ NO ]
      }
    }
  }
  pass5 {
    process {
      layers {
        m1_edge {
          mode [ FREE ]
        }
        vpoly {
          mode [ FREE ]
        }
        TCN {
          mode [ FREE ]
        }
        fixed_metal1 {
          mode [ FREE ]
        }
        tap {
          mode [ FREE ]
        }
      }
    }
    compaction {
      passes {
        nr [ 1 ]
        current [ 5 ]
        last [ YES ]
      }
    }
  }
  execute [
    start
    usershell {
      param { "prop_to_text.csh thirdMig_src" }
    }
    usershell {
      param { remove_polyfill_cell.pl }
      save { remove_polyfill_cell_cif }
    }
    manipulatelayers {
      param { via0SD_to_via0 }
    }
    usershell {
      param {
        "hierarTraverse.csh in/mrmfaadsum9b.cif mrmfaadsum9b.cif.cleanOverlap dataInflate" }
      save { dataInflate_cif }
    }
    himanipulatelayers {
      param { postCleanOverlap }
      save { postCleanOverlap_cif }
    }
    himanipulatelayers {
      param { markDiffVia0 }
      save { markDiffVia0_cif }
    }
    usershell {
      param {
        "hierarTraverse.csh in/mrmfaadsum9b.cif mrmfaadsum9b.cif.diffPromo promoteDiffNoVia0" }
      save { promoteDiffNoVia0_cif }
    }
    himanipulatelayers {
      param { postMarkDiffVia0 }
      save { postMarkDiffVia0_cif }
    }
    himanipulatelayers {
      param { mergeDummytoRealMetal1 }

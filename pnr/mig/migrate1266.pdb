        metal1DiffVia0 { touching(metal1Diff,via0Top) }
        metal1DiffNoVia0 { touchingatmost(metal1Diff,0,via0Top) }
        diffPwr { diffPwrLarge&!(metal1DiffNoVia0+0.005y) }
        diffSgnl { diffSgnlLarge&!(metal1DiffNoVia0+0.005y) }
        diffPwr { diffPwr-0.005y }
        diffSgnl { diffSgnl-0.005y }
        diffPwr { diffPwr-0.0299x+0.0299x }
        diffSgnl { diffSgnl-0.0299x+0.0299x }
        diffPwrLargeWrong { touchingatleast(diffPwrLarge,2,diffPwr) }
        diffPwr { diffPwr&!diffPwrLargeWrong }
        diffSgnlLargeWrong { touchingatleast(diffSgnlLarge,2,diffSgnl) }
        diffSgnl { diffSgnl&!diffSgnlLargeWrong }
        diffWrong { diffPwrLargeWrong|diffSgnlLargeWrong }
        diffPwr { diffPwr&!diffWrong }
        diffSgnl { diffSgnl&!diffWrong }
        diffPwrShift { "sh((diffPwr+0.16x) &! (diffPwr+0.1x))" }
        diffSgnlShift { "sh((diffSgnl+0.16x) &! (diffSgnl+0.1x))" }
        diffPwrStgr { touching(diffPwr,diffSgnlShift) }
        diffSgnlStgr { touching(diffSgnl,diffPwrShift) }
        diffStgr { diffPwrStgr|diffSgnlStgr }
        diffDbl { (diffPwr|diffSgnl)&!diffStgr }
        diffDblExt { (diffDbl+0.1x)&!diffDbl }
        diffDblExtVia0 { touchingatleast(diffDblExt,2,via0Top) }
        diffDbl { touchingatmost(diffDbl,0,diffDblExtVia0) }

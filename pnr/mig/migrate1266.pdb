      new_layers [
        vpoly0 { deleteprop(ALLPROPS,selectshape(POLYGONS,pathtopol(vpoly))) }
        diff0 {
          "deleteprop(ALLPROPS,
                            selectshape(POLYGONS,pathtopol(ndiff|pdiff)))" }
        GCN0 {
          "deleteprop(ALLPROPS,
                           selectshape(POLYGONS,pathtopol(GCN)))" }
        vpolyTop { flattenlayer(vpoly0) }
        diffTop { flattenlayer(diff0) }
        GCNTop { flattenlayer(GCN0) }
        vpolyIsol {
          "touchingatmost(vpolyTop,0,diffTop) &
                     touchingatmost(vpolyTop,0,GCNTop)" }
        gate { diffTop&vpolyTop }
        shield { ((gate+0.16x)&!(gate+0.12x))+0.005y }
        shieldHoleAll { touching(shield,(shield&!vpolyTop)) }
        shieldHole { touchingatmost(shieldHoleAll,1,diffTop) }
        shieldAdd1 { touchingatmost(shieldHole,1,vpolyTop) }
        shieldAdd2 {
          "touchingexact(shieldHole,2,vpolyTop) &
                      touchingatleast(shieldHole,1,vpolyIsol)" }
        shieldAdd { shieldAdd1|shieldAdd2 }
        shieldCutter { (shieldAdd+0.005y)&!shieldAdd }
        shieldCutter {
          "touchingatmost(shieldCutter,0,diffTop) &
                        touchingatmost(shieldCutter,0,GCNTop)" }
        vpolyTop { (vpolyTop|shieldAdd)&!shieldCutter }
        vpolyIsol {
          "touchingatmost(vpolyTop,0,diffTop) &
                     touchingatmost(vpolyTop,0,GCNTop)" }
        shieldError { shieldHoleAll&!shieldAdd }
        vpolyGrid { vpolyTop+0.24y }
        vpolyGap { vpolyGrid&!vpolyTop }
        gapIsol {
          "touchingatmost(vpolyGap,0,diffTop) &
                   touchingatmost(vpolyGap,0,GCNTop)" }
        diffTap { touchingatmost(diffTop,0,vpolyTop) }
        vpolyIsol { touchingatmost(vpolyIsol,0,diffTap+0.03x) }
        gapClose { touchingexact(gapIsol,2,vpolyIsol) }
        vpolyTop { vpolyTop|gapClose }
      ]
      remove_layers [ vpoly0 diff0 GCN0 diffTop GCNTop gate shield
        shieldHoleAll shieldHole shieldAdd1 shieldAdd2 shieldAdd shieldCutter
        diffTap vpolyIsol vpolyGrid vpolyGap gapIsol gapClose ]
    }

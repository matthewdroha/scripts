  rule_fsm_def {
    glue2 {
      PDBVersion { 1.1.1 }
      layers { L1 L2 }
      extend_factor { 1.0 }
      atsamepos { YES }
      fsm [ Start -L1 NoMove 1,NOP 1 1 -L2 Exit 2,BasicXRule(1,2) - Start -L2
        NoMove 1,NOP 2 2 -L1 Exit 2,BasicXRule(1,2) - Start +L1 NoMove 1,NOP 3
        3 +L2 Exit 2,BasicXRule(1,2) - Start +L2 NoMove 1,NOP 4 4 +L1 Exit
        2,BasicXRule(1,2) - ]
    }
    overlapFSM {
      PDBVersion { 1.4.4 }
      rule { overlapFSM }
      layers [ L1 L2 ]
      extend_factor { 1.0 }
      extend_above { YES }
      shadow_sides { YES }
      scan_under { YES }
      already_filter { NO }
      fsm [ Start -L1 Left 1,NOP 1 1 -L2 Left NOP 2 2 +L2 Exit
        2,BasicXRule(1,2) - Start -L2 Nomove NOP 3 3 -L1 Left 1,NOP 4 4 +L2
        Exit 2,BasicXRule(1,2) - Start +L1 Right 1,NOP 5 5 +L2 Right NOP 6 6
        -L2 Exit 2,BasicXRule(1,2) - Start +L2 Nomove NOP 7 7 +L1 Right 1,NOP 8
        8 -L2 Exit 2,BasicXRule(1,2) - ]
    }
    min_segm_length_when_via_at_corner {
      PDBVersion { 1.4.4 }
      rule { min_segm_length_when_via_at_corner }
      layers [ L1 L2 ]
      extend_factor { 1.0 }
      extend_fullstart { YES }
      extend_above { YES }
      extend_through { YES }
      scan_under { YES }
      incrange_through { YES }
      already_filter { NO }
      nomove_overlap { NO }
      fsm [ Start +L1 Left 2,NOP 1 1 -L2 Left 3,NOP 3 1 +L2 Left 3,NOP 3 1 +L1
        NoMove 1,NOP 20 3 +L1 Exit 1,BasicXRule(1,2) - 3 +L2 Left NOP 4 3 +L2
        NoMove NOP 4 4 +L1 Exit 1,BasicXRule(1,2) - 20 +L2 Exit
        3,BasicXRule(1,2) - Start -L1 Right 2,NOP 5 5 +L2 Right 3,NOP 7 5 -L2
        Right 3,NOP 7 5 -L1 NoMove 1,NOP 21 7 -L1 Exit 1,BasicXRule(1,2) - 7
        -L2 Right NOP 8 7 -L2 Nomove NOP 8 8 -L1 Exit 1,BasicXRule(1,2) - 21
        -L2 Exit 3,BasicXRule(1,2) - Start +L1 Right 1,NOP 9 Start +L1 NoMove
        1,NOP 9 Start +L2 NoMove 3,NOP 10 9 +L2 Right 3,NOP 11 9 +L2 NoMove
        3,NOP 12 10 +L1 Right 1,NOP 11 11 +L1 Exit 2,BasicXRule(1,2) - 11 -L2
        Right NOP 12 11 -L2 NoMove NOP 12 12 +L1 Exit 2,BasicXRule(1,2) - Start
        -L1 Left 1,NOP 13 Start -L1 NoMove 1,NOP 13 Start -L2 NoMove 3,NOP 14
        13 -L2 Left 3,NOP 15 13 -L2 NoMove 3,NOP 16 14 -L1 Left 1,NOP 15 15 -L1
        Exit 2,BasicXRule(1,2) - 15 +L2 Left NOP 16 15 +L2 NoMove NOP 16 16 -L1
        Exit 2,BasicXRule(1,2) - ]
    }
    insertextend {
      PDBVersion { 1.1.2 }
      layers { L1 L2 }
      extend_factor { 1.0 }
      keep_borders { NO }
      seethrough_borders { NO }
      ignore_overlap { YES }
      atsamepos { YES }
      fsm [ Start +L1 NoMove 1 1 1 +L2 Exit 2,BasicXRule(1,2) - Start +L2
        NoMove 2 2 2 +L1 Exit 1,BasicXRule(1,2) - Start -L1 NoMove 1 3 3 -L2
        Exit 2,BasicXRule(2,1) - Start -L2 NoMove 2 4 4 -L1 Exit
        1,BasicXRule(2,1) - ]
    }
  }
  layer_arithmetics {
    generatePorts {
      new_layers [
        vpoly_portDrawing {
          "sh(vpoly_portDrawing|selectshapebyprop('portObject YES',vpoly)&vpoly)" }
        TCN_portDrawing {
          "sh(TCN_portDrawing|selectshapebyprop('portObject YES',TCN)&TCN)" }
        GCN_portDrawing {
          "sh(GCN_portDrawing|selectshapebyprop('portObject YES',GCN)&GCN)" }
        metal1_portDrawing {
          "sh(metal1_portDrawing|selectshapebyprop('portObject YES',metal1)&metal1)" }
        metal2_portDrawing {
          "sh(metal2_portDrawing|selectshapebyprop('portObject YES',metal2)&metal2)" }
        metal3_portDrawing {
          "sh(metal3_portDrawing|selectshapebyprop('portObject YES',metal3)&metal3)" }
        metal4_portDrawing {
          "sh(metal4_portDrawing|selectshapebyprop('portObject YES',metal4)&metal4)" }
        metal5_portDrawing {
          "sh(metal5_portDrawing|selectshapebyprop('portObject YES',metal5)&metal5)" }
        metal6_portDrawing {
          "sh(metal6_portDrawing|selectshapebyprop('portObject YES',metal6)&metal6)" }
        metal7_portDrawing {
          "sh(metal7_portDrawing|selectshapebyprop('portObject YES',metal7)&metal7)" }
        metal8_portDrawing {
          "sh(metal8_portDrawing|selectshapebyprop('portObject YES',metal8)&metal8)" }
      ]
    }
    deglue {
      new_layers [
        via1 { via1-0.0005y }
      ]
    }
    cleanchkBoundary {
      new_layers [
        chkBoundary { maxrectangle(chkBoundary) }
      ]
    }
    remove_metals_enclosure_layers {
      remove_layers [ metal1_from_via1 metal2_from_via1 metal2_from_via2
        metal3_from_via2 metal3_from_via3 metal4_from_via3 metal4_from_via4
        metal5_from_via4 metal5_from_via5 metal6_from_via5 metal6_from_via6
        metal7_from_via6 metal7_from_via7 metal8_from_via7 ]
    }
    create_diffSD {
      new_layers [
        diffSD { sh((ndiff|pdiff)&!poly) }
        NSDdiffSD { touchingexact(diffSD,1,vpoly) }
        ndiff { sh(selectshape(POLYGONS,ndiff)) }
        pdiff { sh(selectshape(POLYGONS,pdiff)) }
      ]
    }
    removelock {
      remove_layers { lock lock2 }
    }
    mergeLayers {
      new_layers [
        chkBoundary { chkBoundary }
        nwell { nwell }
        pdiff { pdiff }
        ndiff { ndiff }
        diffSD { diffSD }
        NSDdiffSD { NSDdiffSD }
        tap { tap }
        gated_nacid { gated_nacid }
        TCN { TCN }
        TCNSD { TCNSD }
        metal1 { metal1 }
        metal1_from_via1 { metal1_from_via1 }
        metal2_from_via1 { metal2_from_via1 }
        metal2_from_via2 { metal2_from_via2 }
        metal3_from_via2 { metal3_from_via2 }
        metal3_from_via3 { metal3_from_via3 }
        metal4_from_via3 { metal4_from_via3 }
        metal4_from_via4 { metal4_from_via4 }
        metal5_from_via4 { metal5_from_via4 }
        metal5_from_via5 { metal5_from_via5 }
        metal6_from_via5 { metal6_from_via5 }
        metal6_from_via6 { metal6_from_via6 }
        metal7_from_via6 { metal7_from_via6 }
        metal7_from_via7 { metal7_from_via7 }
        metal8_from_via7 { metal8_from_via7 }
        via0SD { via0SD }
        via0 { via0 }
        via1 { via1 }
        metal2 { metal2 }
        via2 { via2 }
        metal3 { metal3 }
        via3 { via3 }
        metal4 { metal4 }
        via4 { via4 }
        metal5 { metal5 }
        via5 { via5 }
        metal6 { metal6 }
        via6 { via6 }
        metal7 { metal7 }
        via7 { via7 }
        metal8 { metal8 }
        GCN { GCN }
        GCNBox { GCNBox }
        vpoly { vpoly }
        lock { lock }
        lock2 { lock2 }
        cellDummy { cellDummy }
        topDummy { topDummy }
        shield { shield }
        vpoly_portDrawing { vpoly_portDrawing }
        TCN_portDrawing { TCN_portDrawing }
        GCN_portDrawing { GCN_portDrawing }
        metal1_portDrawing { metal1_portDrawing }
        metal2_portDrawing { metal2_portDrawing }
        metal3_portDrawing { metal3_portDrawing }
        metal4_portDrawing { metal4_portDrawing }
        metal5_portDrawing { metal5_portDrawing }
        metal6_portDrawing { metal6_portDrawing }
        metal7_portDrawing { metal7_portDrawing }
        metal8_portDrawing { metal8_portDrawing }
      ]
    }
    remove_ports {
      remove_layers [ ndiff_portDrawing pdiff_portDrawing poly_portDrawing
        metal1_portDrawing metal2_portDrawing metal3_portDrawing
        metal4_portDrawing metal5_portDrawing metal6_portDrawing
        metal7_portDrawing ]
    }
    remove_floating_texts {
      new_layers [
        metal1 { metal1&selectshape(POLYGONS,metal1) }
      ]
    }
    pre1265 {
      new_layers [
        TCNSD { sh(TCN&selectshape(POLYGONS,pdiff|ndiff)) }
        via0SD { maxrectangle(via0&selectshape(POLYGONS,pdiff|ndiff)) }
        via0 { maxrectangle(via0&!touching(via0,via0SD)) }
        vpoly { vpoly|((vpoly+0.005y)&selectshape(POLYGONS,GCN)) }
        tap { selectshape(POLYGONS,((ndiff&nwell)|(pdiff&!nwell))) }
        TCNSD { selectshape(POLYGONS,TCNSD) }
        via0 { selectshape(POLYGONS,via0) }
        via0SD { selectshape(POLYGONS,via0SD) }
        via1 { selectshape(POLYGONS,via1) }
        via2 { selectshape(POLYGONS,via2) }
        via3 { selectshape(POLYGONS,via3) }
        via4 { selectshape(POLYGONS,via4) }
        via5 { selectshape(POLYGONS,via5) }
      ]
      remove_layers { poly GCNBox_max_0.3 GCNBox_tmp GCNBox_tmp_pol }
    }
    jogToMetal {
      rename_layers [
        metal2 { metal2jogs }
      ]
    }
    concvex {
      new_layers [
        nwellflat { flattenlayer(nwell) }
        nwellflat_ { nwellflat-0.01 }
        concave_nwell { ((nwellflat_+0.02x)&(nwellflat_+0.02y)&!nwellflat_) }
        boundflat { flattenlayer(chkBoundary)+0.1 }
        nwell_complement { boundflat&!nwellflat }
        nwell_complement_ { nwell_complement-0.01 }
        convex_nwell {
          ((nwell_complement_+0.02x)&(nwell_complement_+0.02y)&!nwell_complement_) }
      ]
      remove_layers [ nwellflat nwellflat_ boundflat nwell_complement
        nwell_complement_ ]
      rename_layers
    }
    fill_nwell_corner {
      new_layers [
        nwellflat { flattenlayer(nwell) }
        ndiffflat { flattenlayer(ndiff) }
        no_nwell {
          ((ndiffflat&!nwellflat)+0.09y+0.23x)|((nwellflat+0.41y-0.41y+0.32x-0.32x)&!nwellflat) }
        fill {
          touching_exact((touching_exact(((nwellflat+0.32x)&(nwellflat+0.32y)&!nwellflat),0,(no_nwell-0.01))),2,nwell_v_txt) }
        nwell { nwell|fill }
      ]
      remove_layers [ nwellflat ndiffflat no_nwell ]
      rename_layers
    }
    post1265 {
      new_layers [
        metal1_pol { pathtopol(metal1) }
        metal1 { sh(metal1_pol|via0|via0SD|via1) }
      ]
      remove_layers [ device GCNBox metal1_pol ]
      rename_layers [
        ndiff { ndifftxt }
        pdiff { pdifftxt }
        via0 { via0SD }
        TCN { TCNSD }
        metal2 { metal2jogs }
      ]
    }
    remove_metal_hair {
      new_layers [
        metal30 {
          sh(deleteprop(ALLPROPS,selectshape(POLYGONS,pathtopol(metal3)))) }
        metal50 {
          sh(deleteprop(ALLPROPS,selectshape(POLYGONS,pathtopol(metal5)))) }
        metal3Hair { sh(metal30&!((metal30-0.005x)+0.005x)) }
        metal5Hair { sh(metal50&!((metal50-0.005x)+0.005x)) }
      ]
      remove_layers
    }
    vpoly_grid_essential {
      new_layers [
        diff0 { deleteprop(ALLPROPS,selectshape(POLYGONS,(ndiff|pdiff))) }
        vpoly0 { deleteprop(ALLPROPS,selectshape(POLYGONS,pathtopol(vpoly))) }
        TCN0 { deleteprop(ALLPROPS,selectshape(POLYGONS,pathtopol(TCN))) }
        GCN0 { deleteprop(ALLPROPS,selectshape(POLYGONS,pathtopol(GCN))) }
        via00 { deleteprop(ALLPROPS,selectshape(POLYGONS,via0|via0SD)) }
        metal10 { deleteprop(ALLPROPS,selectshape(POLYGONS,pathtopol(metal1))) }
        diffTop { flattenlayer(diff0) }
        vpolyTop { flattenlayer(vpoly0) }
        TCNtop { flattenlayer(TCN0) }
        GCNtop { flattenlayer(GCN0) }
        via0top { flattenlayer(via00) }
        metal1top { flattenlayer(metal10) }
        vpolyGCNTCN { vpolyTop&GCNtop&TCNtop }
        via0metal1 { touchingatmost(via0top&metal1top,0,GCNtop) }
        TCNdrop0 { touchingexact(TCNtop,1,vpolyGCNTCN) }
        TCNdrop { touchingatmost(TCNdrop0,0,via0metal1) }
        TCNessential { TCNtop&!TCNdrop }
        vpolyDrop0 { touchingatmost(vpolyTop,0,diffTop) }
        vpolyDrop { touching(vpolyDrop0,TCNessential) }
        vpolyEssential { vpolyTop&!vpolyDrop }
        vpoly { vpoly&!(vpoly&!vpolyEssential) }
        TCN { TCN&!(TCN&!TCNessential) }
        vpolyrec { maxrectangle(vpolyEssential) }
        cellBorder0 { sh((chkBoundary+0.02x)&!(chkBoundary-0.02x)) }
        cellBorderTop0 { flattenlayer(cellBorder0) }
        cellBorderTop1 { cellBorderTop0&!((cellBorderTop0-0.02x)+0.02x) }
        cellBorder1 { cellBorder0&!(cellBorder0&!cellBorderTop1) }
        cellBorder2 { touchingatleast(cellBorder1,1,chkBoundary) }
        leftCellBorder0 { touching(cellBorder2,chkBoundary-0.04r) }
        rightCellBorder0 { touching(cellBorder2,chkBoundary-0.04l) }
        vpoly_border_left { sh(leftCellBorder0&!(leftCellBorder0-0.04b)) }
        vpoly_border_right { sh(rightCellBorder0&!(rightCellBorder0-0.04t)) }
      ]
      remove_layers [ diff0 diffTop vpoly0 vpolyTop TCN0 TCNtop GCN0 GCNtop
        via00 via0top metal10 metal1top vpolyGCNTCN via0metal1 TCNdrop0 TCNdrop
        TCNessential vpolyDrop0 vpolyDrop vpolyEssential cellBorder0
        cellBorderTop0 cellBorderTop1 cellBorder1 cellBorder2 leftCellBorder0
        rightCellBorder0 ]
    }
    TCN_metal1_grid_essential {
      new_layers [
        diff0 { deleteprop(ALLPROPS,selectshape(POLYGONS,(ndiff|pdiff))) }
        vpoly0 { deleteprop(ALLPROPS,selectshape(POLYGONS,pathtopol(vpoly))) }
        TCN0 { deleteprop(ALLPROPS,selectshape(POLYGONS,pathtopol(TCN))) }
        GCN0 { deleteprop(ALLPROPS,selectshape(POLYGONS,pathtopol(GCN))) }
        via0SD0 { deleteprop(ALLPROPS,selectshape(POLYGONS,via0SD)) }
        via00 { deleteprop(ALLPROPS,selectshape(POLYGONS,via0)) }
        metal10 { pathtopol(metal1) }
        metal11 { deleteprop(ALLPROPS,selectshape(POLYGONS,metal10)) }
        via10 { deleteprop(ALLPROPS,selectshape(POLYGONS,via1)) }
        diffTop { flattenlayer(diff0) }
        vpolyTop { flattenlayer(vpoly0) }
        tranTop { vpolyTop&diffTop }
        TCNtop { flattenlayer(TCN0) }
        GCNtop { flattenlayer(GCN0) }
        via0SDTop { flattenlayer(via0SD0) }
        via0Top { flattenlayer(via00) }

    himanipulatelayers {
      param { GCN2metal1 }
      save { GCN2metal1_cif }
    }
    manipulatelayers {
      param { remove_trans }
    }
    analyzedevices
    usershell {
      param { "handle_ports_by_texts.csh in/mrmfaadsum9b.cif" }
      save { handle_ports_by_texts_cif }
    }
    manipulatelayers {
      param { create_NSDdiffSD_from_diffSD }
    }
    manipulatelayers {
      param { "create_metal1SD m1_p2p_create" }
      save { m1_p2p_create_cif }
    }
    usershell {
      param { "convert_small_path_to_pol.pl mrmfaadsum9b p1266" }
    }
    himanipulatelayers {
      param { p2p_cleanup }
      save { p2p_cleanup_cif }
    }
    usershell {
      param { "splitpath.pl mrmfaadsum9b 0.08000 metal1" }
    }
    usershell {
      param { "addgridlines.pl mrmfaadsum9b X polygrid TCNgrid 0.16000 0.20000" }
      save { addgridlines_cif }
    }
    himanipulatelayers {
      param { createFixedObjectsRectangles }
      save { createFixedObjectsRectangles_cif }
    }
    himanipulatelayers {
      param { "mark_nwell_corners markTopBorder extend_GCN" }
      save { extend_GCN_cif }
    }
    usershell {
      param {
        "hierarTraverse.csh in/mrmfaadsum9b.cif mrmfaadsum9b.cif.fillVpoly dummyVpoly" }
      save { dummyVpoly_cif }
    }
    usershell {
      param { "move_vpolyTop_layers_to_container.csh Shmuels_dummies_1" }
      save { dummyVpolyContainer_cif }
    }
    himanipulatelayers {
      param { closeSafePolyGaps }
      save { closeSafePolyGaps1_cif }
    }
    usershell {
      param { "move_vpolyTop_layers_to_container.csh Shmuels_dummies_1" }
      save { closeSafePolyGapsContainer1_cif }
    }
    usershell {
      param {
        "containerReorg.csh in/mrmfaadsum9b.cif mrmfaadsum9b.cif.promoteContainer mrmfaadsum9b_polyfill promote" }
    }
    usershell {
      param {
        "hierarTraverse.csh in/mrmfaadsum9b.cif mrmfaadsum9b.cif.cleanOverlap dataInflate" }
      save { dataInflate2_cif }
    }
    himanipulatelayers {
      param { "postCleanOverlap m1_p2p_create" }
      save { dummyVpoly_postCleanOverlap_cif }
    }
    usershell {
      param {
        "containerReorg.csh in/mrmfaadsum9b.cif mrmfaadsum9b.cif.demoteContainer mrmfaadsum9b_polyfill demote" }
    }
    himanipulatelayers {
      param { mark_vpolySR }
    }
    manipulatelayers {
      param { port_txt_to_metal_txt }
    }
    usershell {
      param {
        "cellSwap.csh ../../src/mrmfaadsum9b.cif in/mrmfaadsum9b.cif mrmfaadsum9b.cif.cellSwap ../../auxiliaries/PS3_do_not_touch_cells_rgexp.list swappedCells.list auxiliaries/mrmfaadsum9b_PS3_skipCells.list" }
    }
    restorecif
    addinfo
    himanipulatelayers {
      param { Align_metal1 }
      save { symlib }
    }
    usershell {
      param { "prop_to_text.csh thirdMig_symlib" }
    }
    activatepdb {
      param { pass1 }
    }
    inheritrules {
      save { pre_last_compaction_pass }
    }
    compactcells {
      save { compacted1 }
    }
    usershell {
      param { "save_migrate_file.csh pass1" }
    }
    himanipulatelayers {
      param { "free_nwell vpolyToGap" }
    }
    usershell {
      param {
        "containerReorg.csh in/mrmfaadsum9b.cif mrmfaadsum9b.cif.promoteContainer mrmfaadsum9b_polyfill promote" }
    }
    usershell {
      param {
        "hierarTraverse.csh in/mrmfaadsum9b.cif mrmfaadsum9b.cif.cleanOverlap dataInflate" }
      save { compacted2_symlib }
    }
    himanipulatelayers {
      param { "postCleanOverlap m1_p2p_create" }
    }
    usershell {
      param {
        "containerReorg.csh in/mrmfaadsum9b.cif mrmfaadsum9b.cif.demoteContainer mrmfaadsum9b_polyfill demote" }
      save { compacted2_symlib }
    }
    activatepdb {
      param { pass2 }
    }
    compactcells {
      save { compacted2 }
    }
    usershell {
      param { "save_migrate_file.csh pass2" }
    }
    himanipulatelayers {
      param { "Align_metal1 mark_nwell_corners" }
      save { compacted3_symlib }
    }
    activatepdb {
      param { pass3 }
      save { pre_last_compaction_pass }
    }
    compactcells {
      save { compacted3 }
    }
    usershell {
      param { "save_migrate_file.csh pass3" }
    }
    himanipulatelayers {
      param { closeSafePolyGaps }
      save { closeSafePolyGaps2_cif }
    }
    usershell {
      param { "move_vpolyTop_layers_to_container.csh Shmuels_dummies_1" }
      save { closeSafePolyGapsContainer2_cif }
    }
    himanipulatelayers {
      param { "PL_03_fix PL_62_fix_1 PL_62_fix_2" }
    }
    usershell {
      param { "move_vpolyTop_layers_to_container.csh Shmuels_dummies_2" }
    }
    himanipulatelayers {
      param { mark_vpolySR }
      save { PL_03_62_fix_cif }
    }
    usershell {
      param {
        "containerReorg.csh in/mrmfaadsum9b.cif mrmfaadsum9b.cif.promoteContainer mrmfaadsum9b_polyfill promote" }
    }
    usershell {
      param {
        "hierarTraverse.csh in/mrmfaadsum9b.cif mrmfaadsum9b.cif.cleanOverlap dataInflate" }
    }
    himanipulatelayers {
      param { "postCleanOverlap m1_p2p_create" }
    }
    usershell {
      param {
        "containerReorg.csh in/mrmfaadsum9b.cif mrmfaadsum9b.cif.demoteContainer mrmfaadsum9b_polyfill demote" }
    }
    addinfo {
      save { compacted4_symlib }
    }
    activatepdb {
      param { pass4 }
    }
    compactcells {
      save { compacted4 }
    }
    usershell {
      param { "save_migrate_file.csh pass4" }
    }
    himanipulatelayers {
      param { Align_metal1 }
    }
    activatepdb {
      param { pass5 }
    }
    compactcells {
      save { compacted5 }
    }
    manipulatelayers {
      param { Update_vpolySR_big_size }
    }
    himanipulatelayers {
      param { metal2via1TopPads_to_metal2 }
      save { metal2via1TopPads_to_metal2_cif }
    }
    himanipulatelayers {
      param { split_vpoly_to_active_or_dummy }
    }
    usershell {
      param {
        "split_vpolyContainer_to_active_or_dummy.pl in/mrmfaadsum9b.cif in/mrmfaadsum9b.cif" }
      save { split_vpolyContainer_to_active_or_dummy_cif }
    }
    manipulatelayers {
      param { rename_to_vpoly }
      save { solve_Carmel_issue_cif }
    }
    usershell {
      param { reproduce_ports_by_SF.csh }
      save { reproduced_ports_cif }
    }
    restorecif
    usershell {
      param { "prop_to_text.csh thirdMig_results" }
    }
    usershell {
      param { cpResults.csh }
    }
  ]
  layout {
    cell_mode { FREE }
    instance_mode { FREE }
    type { CIF }
    cif {
      sourcedir { src-thirdMig }
      outputdir { result-thirdMig }
    }
    classes {
      FIXED_CELLS {
        mode { FIXED }
        members
      }
    }
  }
  connectivity {
    CN_DIFF {
      connect { diffSD,TCN,GCN }
    }
    CN_NSDDIFF {
      connect { NSDdiffSD,TCN,GCN }
    }
    GCN_VPOLY {
      connect { GCN,vpoly }
    }
    METAL2_SCHEME {
      connect { metal2,metal2jogs }
    }
    VIA1_VIA2_SCHEME {
      connect { via1,metal2 metal2,via2 }
    }
    VIA2_VIA3_SCHEME {
      connect { via2,metal3 metal3,via3 }
    }
    VIA3_VIA4_SCHEME {
      connect { via3,metal4 metal4,via4 }
    }
    VIA4_VIA5_SCHEME {
      connect { via4,metal5 metal5,via5 }
    }
    VIA5_VIA6_SCHEME {
      connect { via5,metal6 metal6,via6 }
    }
    VIA6_VIA7_SCHEME {
      connect { via6,metal7 metal7,via7 }
    }
    VIA7_VIA8_SCHEME {
      connect { via7,metal8 metal8,via8 }
    }
    CN_NSDDIFF_EXTENDED {
      connect { NSDdiffSD,TCN,GCN TCN,GCN,via0 via0,metal1 TCN,GCN,via0SD
        via0SD,metal1 }
    }
    GCN_TCN_SCHEME {
      connect { GCN,TCN,via0 via0,metal1 GCN,TCN,via0SD via0SD,metal1 }
    }
    VIA0_VIA1_SCHEME {
      connect { via0,metal1 metal1,via1 via0SD,metal1 }
    }
    VIA0_CN_SCHEME {
      connect { via0,TCN,GCN via0,metal1 via0SD,TCN,GCN via0SD,metal1 }
    }
    VIA0_DIFF_SCHEME {
      connect { via0,TCN TCN,diffSD via0SD,TCN }
    }
  }

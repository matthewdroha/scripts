            }
          }
        ]
      }
      aligndiffTCNg-atleast {
        enforce { YES }
        rule { glue2 }
        layers [ TCN  ndiff|pdiff ]
        priority { 0 }
        extend_distance [ 0.0 ]
        value {
          atleast { 0.0 }
        }
      }
      aligndiffTCNg-atmost {
        enforce { YES }
        rule { glue2 }
        layers [ TCN  ndiff|pdiff ]
        priority { 0 }
        extend_distance [ 0.0 ]

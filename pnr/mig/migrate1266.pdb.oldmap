    rules {
      sdiffGCN {
        rule { space }
        layers [ ndiff|pdiff  GCN ]
        priority { 90 }
        conditions [
          passis(ydirection) {
            value {
              atleast { 0.11 }
              metric { BOX }
              box_height { 0.055 }
            }
          }
          default {
            value {
              atleast { 0.055 }
            }
          }
        ]
      }
      sndiff {
        rule { space }
        layers [ ndiff ]
        priority { 90 }
        conditions [
          "passis(xdirection)&!((next(next(edge(1)))==edge(2))
             |(next(next(edge(2)))==edge(1)))" {
            value {
              atleast { 0.14 }
            }
          }
          "passis(ydirection)&!((next(next(edge(1)))==edge(2))
             |(next(next(edge(2)))==edge(1)))" {
            value {
              atleast { 0.165 }
            }
          }
        ]
      }
      sndifflvs {
        rule { space }
        layers [ ndiff ]
        priority { 100 }
        value {
          atleast { 2*0.0005 }
        }
      }
      spdiff {
        rule { space }
        layers [ pdiff ]
        priority { 90 }
        conditions [
          "passis(xdirection)&!((next(next(edge(1)))==edge(2))
             |(next(next(edge(2)))==edge(1)))" {
            value {
              atleast { 0.14 }
            }
          }
          "passis(ydirection)&!((next(next(edge(1)))==edge(2))
             |(next(next(edge(2)))==edge(1)))" {
            value {
              atleast { 0.165 }
            }
          }
        ]
      }
      spdifflvs {
        rule { space }
        layers [ pdiff ]
        priority { 100 }
        value {
          atleast { 2*0.0005 }
        }
      }
      sGCN {
        rule { space }
        layers [ GCN ]
        priority { 90 }
        conditions [
          passis(xdirection)&overlap(edge(1),edge(2))>0 {
            value {
              atleast { 0.11 }
            }
            priority { 90 }
          }
          passis(ydirection)&overlap(edge(1),edge(2))>0 {
            value {
              atleast { 0.137 }
            }
            priority { 90 }
          }
          default {
            value {
              atleast { 0.087 }
            }
          }
        ]
      }
      sGCNlvs {
        rule { space }
        layers [ GCN ]
        priority { 100 }
        value {
          atleast { 2*0.0005 }
        }
      }
      lGCN {
        rule { length }
        layers [ GCN ]
        toplevel_only { YES }
        priority { 90 }
        conditions [
          passis(xdirection)&(length(edge(1))>0.08) {
            value {
              atleast { 0.192 }
            }
          }
        ]
      }
      xGCNGCNBox {
        rule { extend }
        priority { 80 }
        layers [ GCN  GCNBox ]
        metric { MANHATTAN }
        conditions [
          passis(ydirection)&distance(edge(1),edge(2))<0.1 {
            value {
              exact { 0.0 }
            }
          }
        ]
      }
      sgateTCN {
        rule { space }
        priority { 200 }
        layers [ TCN  vpoly&(ndiff|pdiff) ]
        metric { MANHATTAN }
        conditions [
          passis(xdirection)&distance(edge(1),edge(2))<2*0.04 {
            value {
              exact { 0.04 }
            }
          }
        ]
      }
      sTCN {
        rule { space }
        layers [ TCN ]
        conditions [
          passis(xdirection)&overlap(edge(1),edge(2))>0 {
            value {
              atleast { 0.135 }
            }
            priority { 90 }
          }
          passis(ydirection)&overlap(edge(1),edge(2))>0 {
            value {
              atleast { 0.1925 }
            }
            priority { 90 }
          }
        ]
      }
      sTCNlvs {

{
  reallyuglyworkaround { advancedmacros }
  grid { 0.0005 }
  processgrid { 0.005 }
  polypitch { 0.22 }
  polywidth { 0.055 }
  metal1width { 0.055 }
  halfpolywidth { 0.0275 }
  cellpitch { 0.22 }
  GCNpitch { 0.275 }
  rule_fsm_def {
    glue2 {
      PDBVersion { 1.1.1 }
      layers { L1  L2 }
      extend_factor { 1.0 }
      verticalfsm { WIDE }
      atsamepos { YES }
      fsm [ Start  -L1  NoMove  1,NOP  1  1  -L2  Exit  2,BasicXRule(1,2)  -  
        Start  -L2  NoMove  1,NOP  2  2  -L1  Exit  2,BasicXRule(1,2)  -  Start 
         +L1  NoMove  1,NOP  3  3  +L2  Exit  2,BasicXRule(1,2)  -  Start  +L2  
        NoMove  1,NOP  4  4  +L1  Exit  2,BasicXRule(1,2)  - ]
    }
  }
  viewer {
    layers {
      OC {
        color { yellow }
        style { Stippled }
        pattern { checker1 }
      }
      OC_RUL {
        color { yellow }
        style { Stippled }
        pattern { checker1 }
      }
      CRX {
        color { yellow }
        style { Stippled }
        pattern { checker1 }
      }
      CRX_RUL {
        color { yellow }
        style { Stippled }
        pattern { checker1 }
      }
      CRY {
        color { yellow }
        style { Stippled }
        pattern { checker1 }
      }
      CRY_RUL {
        color { yellow }
        style { Stippled }
        pattern { checker1 }
      }
      RUL {
        color { green }
        style { Hollow }
        pattern { checker1 }
      }
      UC {
        color { yellow }
        style { Hollow }
        pattern { checker1 }
      }
      ERR {
        color { yellow }
        style { Hollow }
        pattern { checker1 }
      }
      chkBoundary {
        color { "255 255 255" }
        style { Hollow }
        priority { 200 }
      }
      poly_portDrawing {
        color { "0 170 170" }
        style { Hollow }
      }
      metal1_portDrawing {
        color { "180 0 0" }
        style { Hollow }
      }
      metal2_portDrawing {
        color { "80 80 144" }
        style { Hollow }
      }
      metal3_portDrawing {
        color { "170 0 170" }
        style { Hollow }
      }
      metal4_portDrawing {
        color { "200 200 0" }
        style { Hollow }
      }
      metal5_portDrawing {
        color { "80 144 80" }
        style { Hollow }
      }
      metal6_portDrawing {
        color { "255 107 107" }
        style { Hollow }
      }
      nwell {
        color { "80 144 80" }
        style { Stippled }
        pattern { zigzag1 }
        priority { 100 }
      }
      ndiff {
        color { "0 240 0" }
        style { Stippled }
        pattern { zigzag1 }
        priority { 95 }
      }
      pdiff {
        color { "240 0 240" }
        style { Stippled }
        pattern { zigzag1 }
        priority { 95 }
      }
      GCN {
        color { "0 211 239" }
        style { Stippled }
        pattern { zigzag1 }
        priority { 90 }
      }
      vpoly {
        color { "0 240 240" }
        style { Stippled }
        pattern { zigzag1 }
        priority { 90 }
      }
      poly {
        color { "0 240 240" }
        style { Stippled }
        pattern { zigzag1 }
        priority { 90 }
      }
      contact {
        color { "240 240 0" }
        style { Solid }
        priority { 80 }
      }
      TCN {
        color { "198 198 198" }
        style { Stippled }
        pattern { zigzag1 }
        priority { 85 }
      }
      metal1 {
        color { "240 0 0" }
        style { Stippled }
        pattern { zigzag1 }
        priority { 85 }
      }
      vmetal1 {
        color { "240 0 0" }
        style { Stippled }
        pattern { zigzag1 }
        priority { 85 }
      }
      hmetal1 {
        color { "180 0 0" }
        style { Stippled }
        pattern { zigzag1 }
        priority { 85 }
      }
      via0 {
        color { "240 128 0" }
        style { Solid }
        priority { 70 }
      }
      via0SD {
        color { "240 128 0" }
        style { Solid }
        priority { 70 }
      }
      via1 {
        color { "251 24 150" }
        style { Solid }
        priority { 70 }
      }
      metal2 {
        color { "108 108 253" }
        style { Stippled }
        pattern { zigzag1 }
        priority { 75 }
      }
      via2 {
        color { "108 108 253" }
        style { Solid }
        priority { 60 }
      }
      metal3 {
        color { "255 168 255" }
        style { Stippled }
        pattern { zigzag1 }
        priority { 65 }
      }
      via3 {
        color { "217 109 157" }
        style { Solid }
        priority { 50 }
      }
      metal4 {
        color { "240 240 0" }
        style { Stippled }
        pattern { zigzag1 }
        priority { 55 }
      }
      via4 {
        color { "240 128 0" }
        style { Solid }
        priority { 40 }
      }
      metal5 {
        color { "0 198 0" }
        style { Stippled }
        pattern { zigzag1 }
        priority { 45 }
      }
      via5 {
        color { "237 131 255" }
        style { Solid }
        priority { 30 }
      }
      metal6 {
        color { "255 107 107" }
        style { Stippled }
        pattern { zigzag1 }
        priority { 35 }
      }
      via6 {
        color { "3 239 0" }
        style { Solid }
        priority { 30 }
      }
      metal7 {
        color { "179 0 234" }
        style { Stippled }
        pattern { zigzag1 }
        priority { 35 }
      }
      polygrid { color { "red" } }
      TCNgrid { color { "green" } }
    }
  }
  pitchpriority { 200 }
  polypitchpriority { 190 }
  metal1pitchpriority { 180 }
  rulespriority { 90 }
  lvspriority { 100 }
  tologypriority { 99 }
  boundarypriority { 96 }
  niceocpriority { 95 }
  nicetohavepriority { -10 }
  alignmentpriority { 80 }
  layer_arithmetics {
    settings {
      verbose { YES }
      path_type { FLUSH }
      keep_path_connectivity { YES }
    }
    deglue {
      new_layers [
        via1 { via1-0.0005y }
      ]
    }
    removelock {
      remove_layers { lock }
    }
    clean {
      new_layers [
        chkBoundary { chkBoundary }
        nwell { nwell }
        pdiff { pdiff }
        ndiff { ndiff }
        contact { contact }
        TCN { TCN }
        TCNSD { TCNSD }
        metal1 { metal1 }
        vmetal1 { vmetal1 }
        hmetal1 { hmetal1 }
        via0SD { via0SD }
        via0 { via0 }
        via1 { via1 }
        metal2 { metal2 }
        via2 { via2 }
        metal3 { metal3 }
        via3 { via3 }
        metal4 { metal4 }
        GCN { GCN }
        GCNBox { GCNBox }
        vpoly { vpoly }
        lock { lock }
      ]
    }
    pre1265 {
      new_layers [
        GCN { sh(GCN+0.005) }
        GCNBox_max_0.3 { maxpathwidth(poltopath(GCN),0.3) }
        GCNBox_tmp { pathendsize(GCNBox_max_0.3+0.4) }
        GCNBox_tmp_pol { pathtopol(GCNBox_tmp) }
        GCNBox { GCNBox_tmp_pol-0.4x }
        via1 { sh((via1+0.085-0.085)&(metal1|metal1_up_1L)&metal2) }
        metal0SD { sh(metal0&(pdiff|ndiff)) }
        via0SD { maxrectangle(via0&(pdiff|ndiff)) }
        via0 { maxrectangle(via0&!touching(via0,via0SD)) }
      ]
      remove_layers { poly  GCNBox_max_0.3  GCNBox_tmp  GCNBox_tmp_pol }
    }
    post1265 { new_layers  remove_layers }
    create_tran {
      new_layers [
        NTRAN { sh(ndiff&poly) }
        PTRAN { sh(pdiff&poly) }
      ]
    }
    clean_gate_fill {
      new_layers [
        fill_0 { top_gate_fill&!cell_gate_fill }
        trim { (poly+0.11y)+0.055x }
        fill_1 { fill_0&!trim }
        fill_2 { (fill_1-0.027x)+0.027x }
        fill_3 { cell_gate_fill&!trim }
        fill_4 { (fill_3-0.027x)+0.027x }
        fill_5 { (fill_2|fill_4)&!(((fill_2|fill_4)-0.11y)+0.11y) }
        top_gate_fill { fill_2&!fill_5 }
        cell_gate_fill { fill_4&!fill_5 }
      ]
      remove_layers [ trim  fill_0  fill_1  fill_2  fill_3  fill_4  fill_5 ]
    }
    split_poly {
      new_layers [
        diff0 { sh(selectshape(POLYGONS,(ndiff|pdiff))) }
        poly0 { sh(selectshape(POLYGONS,poly)) }
        contact0 { sh(selectshape(POLYGONS,contact)) }
        contact0a { flattenlayer(contact0) }
        poly0a { flattenlayer(poly0) }
        contactPoly { touching(contact0a,poly0a) }
        polyContact { touching(poly0a,contact0a) }
        poly0b { poly0&!(poly0a&!polyContact) }
        contact0b { poly0b&!(poly0b&!contactPoly) }
        contact0 { sh(contact0|contact0b) }
        vpoly0a { touchingatmost(poly0&!(poly0-0.025x+0.025x),0,contact0-0.005) 
          }
        hpoly0a { poly0&!vpoly0a }
        vpoly0b { 
          sh(touchingatmost(hpoly0a&!((hpoly0a-0.105x)+0.105x),0,contact0)) }
        hpoly0b { sh(hpoly0a&!vpoly0b) }
        vpoly0c { sh(vpoly0a|vpoly0b) }
        hpoly0c { sh(touching((hpoly0b+0.11-0.11)&poly0,hpoly0b)) }
        vhpoly0 { touching(vpoly0c&(hpoly0c+0.12x),hpoly0c) }
        vhpoly1 { touching(hpoly0c&(vpoly0c+0.32y),vpoly0c) }
        hpoly { sh(hpoly0c|vhpoly0) }
        vpoly { sh(vpoly0c|vhpoly1) }
        poly { poly&(hpoly|vpoly) }
        polyXor { ((poly0&!(hpoly|vpoly))|((hpoly|vpoly)&!poly0)) }
      ]
      remove_layers [ diff0  poly0  contact0  contact0a  poly0a  contactPoly  
        polyContact  poly0b  contact0b  vpoly0a  hpoly0a  vpoly0b  hpoly0b  
        vpoly0c  hpoly0c  vhpoly0  vhpoly1 ]
    }
    metal1_to_CN {
      new_layers [
        poly0 { sh(selectshape(POLYGONS,poly)) }
        metal10a { sh(selectshape(POLYGONS,metal1)) }
        metal10 { metal10a&!(metal10a&!metal10a) }
        contact0 { sh(selectshape(POLYGONS,contact)) }
        diff0 { sh(selectshape(POLYGONS,(ndiff|pdiff))) }
        tran_marker { sh((poly0&diff0)+0.2x) }
        non_tran_marker { sh(touchingatmost(diff0,0,poly0)) }
        vhpoly0 { vpoly&hpoly }
        hpoly0 { hpoly&!(vhpoly0) }
        intfPoly { (touchingatmost(vhpoly0,1,hpoly0))+0.165x+0.055y }
        intfPolyM1top { flattenlayer(intfPoly)&flattenlayer(metal10) }
        intfPolyM1 { metal10&!(metal10&!intfPolyM1top) }
        polyMetal1 { (metal10+0.005)&(poly0+0.005) }
        poly_m1_contact_marker { touching(polyMetal1,(polyMetal1&contact0)) }
        poly_m1_pass_marker { polyMetal1&!poly_m1_contact_marker }
        CN0 { sh(touching(((metal10&!(poly0+0.01x))&diff0),contact0)) }
        metal1Bridge0 { metal10&(poly0+0.01x)&diff0 }
        CN1 { sh(touching(CN0,tran_marker)) }
        vCN1 { sh(CN1&((CN1-0.1y)+0.1y)) }
        hCN1 { sh(CN1&!vCN1) }
        CN2 { sh(CN1&!touching(hCN1,vCN1)) }
        CN3a { touching(((metal10&!diff0)-0.05+0.05),CN2) }
        CN3b { touchingatmost(CN3a,0,non_tran_marker) }
        CN3 { touchingatmost(CN3b,0,diff0&!(CN2+0.05)) }
        CN4a { touchingatmost((CN3&!poly0),0,poly_m1_pass_marker)-0.05+0.05 }
        CN4top { 
          touchingatmost(flattenlayer(CN4a),0,flattenlayer(poly_m1_pass_marker)) 
          }
        CN4 { CN4a&!(CN4a&!CN4top) }
        CN5 { 
          sh(touchingatleast(CN4,2,(CN2&diff0))&touchingatmost(CN4,0,poly_m1_contact_marker)) 
          }
        CN6 { sh(touching(CN4,CN2)&touchingexact(CN4,1,poly_m1_contact_marker)) 
          }
        CN7 { 
          sh(touchingatmost(CN4,0,(CN2&diff0))&touching(CN4,poly_m1_contact_marker)) 
          }
        border { sh((chkBoundary+0.005)&!chkBoundary) }
        CN8 { sh(touchingexact(CN4,1,CN2)&touchingexact(CN4,1,border)) }
        CN { sh(CN5|CN6|CN7|CN8) }
        GCN { CN-0.115x+0.115x }
        TCNa { CN&!GCN }
        TCN { (touchingatmost(TCNa,0,intfPolyM1)&(TCNa&!intfPolyM1))|CN2 }
        CN_overlap0 { (touching(GCN,TCN)+0.005x)&(touching(TCN,GCN)+0.005y) }
        CN_overlap1 { (touching(GCN,TCN)+0.11x)&(touching(TCN,GCN)+0.11y) }
        CN_overlap { touching(CN_overlap1,CN_overlap0)&metal10 }
        GCN { sh(GCN|CN_overlap) }
        TCN { sh(TCN|CN_overlap) }
        metal1Bridge { touchingatleast(metal1Bridge0,2,TCN) }
        CNmetal1Diff { (TCN|GCN)&!metal10 }
      ]
      remove_layers [ poly0  vpoly0  hpoly0  metal10a  metal10  contact0  diff0 
         tran_marker  non_tran_marker  polyMetal1  poly_m1_contact_marker  
        poly_m1_pass_marker  vhpoly0  hpoly0  intfPoly  intfPolyM1top  
        intfPolyM1  CN0  CN1  hCN1  vCN1  CN2  CN3  CN3a  CN3b  CN4a  CN4top  
        CN4  CN5  CN6  CN7  CN8  border  CN  TCNa  CN_overlap0  CN_overlap1  
        CN_overlap  metal1Bridge0 ]
    }
    redefine_metal1 {
      new_layers [
        metal10a { sh(selectshape(POLYGONS,metal1)) }
        metal10 { metal10a&!(metal10a&!metal10a) }
        via10 { sh(selectshape(POLYGONS,via1)) }
        CN { GCN|TCN }
        metal11 { ((metal10&!CN)-0.04+0.04)|metal1Bridge }
        CNframe { sh(CN&!(CN-0.02)) }
        via0a { (CNframe-0.02x)&(metal11+0.02y) }
        via0b { (CNframe-0.02y)&(metal11+0.02x) }
        metal1PadA { touching((metal11+0.02y)&!metal11,via0a) }
        metal1PadB { touching((metal11+0.02x)&!metal11,via0b) }
        CNvia1Intersect { touchingatmost(CN&via10,0,(via0a|via0b)&via10) }
        via0 { sh(via0a|via0b|CNvia1Intersect) }
        metal1Pad { metal1PadA|metal1PadB|CNvia1Intersect }
        GCN { GCN&metal1 }
        TCN { TCN&metal1 }
        metal12 { (metal11|metal1Pad|via10)&metal1 }
        metal1 { metal12+0.02-0.02 }
        metal1Diff { selectshape(POLYGONS,metal1)&!metal10 }
      ]
      remove_layers [ metal10a  metal10  via10  CN  metal11  CNframe  via0a  
        via0b  metal1PadA  metal1PadB  metal1Pad  CNvia1Intersect  metal12  
        contactOld  metal1Bridge ]
    }
    merge_via0 {
      new_layers [
        TCN0 { sh(selectshape(POLYGONS,TCN)) }
        via00 { sh(selectshape(POLYGONS,via0)) }
        metal10 { sh(selectshape(POLYGONS,metal1)) }
        via0TCN { TCN0&!(TCN0&!via00) }
        metal1TCN { TCN0&!(TCN0&!metal10) }
        TCN0a { touchingatleast(TCN0,2,via0TCN) }
        TCN0b { TCN0a&!touching(metal1TCN,via0TCN) }
        TCN0c { touching(TCN0b,touchingatmost(metal1TCN,0,via0TCN)) }
        TCN0d { TCN0b&!TCN0c }
        via00a { (via0TCN+0.11)&touching(TCN0,TCN0d) }
        via00b { touchingatleast(via00a,2,via0TCN) }
        via0 { via0|via00b }
        metal1 { metal1|via00b }
      ]
      remove_layers [ TCN0  via00  metal10  via0TCN  metal1TCN  TCN0a  TCN0b  
        TCN0c  TCN0d  via00a  via00b ]
    }
    remove_contacts {
      new_layers [
        diff0 { sh(selectshape(POLYGONS,(ndiff|pdiff))) }
        poly0 { sh(selectshape(POLYGONS,poly)) }
        hpoly0 { sh(selectshape(POLYGONS,hpoly)) }
        contact0 { sh(selectshape(POLYGONS,contact)) }
        metal10 { sh(selectshape(POLYGONS,metal1)) }
        non_tran_diff { sh(touchingatmost(diff0,0,poly0)) }
        hpolyMetal1Contact { hpoly0&metal10&contact0 }
        hpolyMetal1Land { touching(hpoly0&metal10,hpolyMetal1Contact) }
        tapMetal1Contact { non_tran_diff&metal10&contact0 }
        tapMetal1Land { touching(non_tran_diff&metal1,tapMetal1Contact) }
        GCN { GCN|hpoly }
        TCN { TCN|tapMetal1Land }
        via0a { via0|(hpolyMetal1Land&metal1&hpoly0)|(tapMetal1Land&metal1) }
        via0b { (via0a+0.11-0.11)&metal1&(GCN|TCN) }
        via0 { maxrectangle(touching(via0b,via0a)-0.005) }
        contact { contact&!((GCN|TCN)|touching(contact,hpoly0)) }
        poly { poly&!(vpoly|hpoly) }
      ]
      remove_layers [ diff0  poly0  hpoly0  contact0  metal10  non_tran_diff  
        hpolyMetal1Contact  hpolyMetal1Land  tapMetal1Contact  tapMetal1Land  
        via0a  via0b  hpoly ]
    }
    clean_metal1 {
      new_layers [
        via00 { sh(selectshape(POLYGONS,via0)) }
        metal10 { sh(selectshape(POLYGONS,metal1)) }
        via10 { sh(selectshape(POLYGONS,via1)) }
        metal10a { flattenlayer(metal10) }
        metal1Via0 { metal10a&flattenlayer(via00) }
        metal1Via1 { metal10a&flattenlayer(via10) }
        metal10b { touchingatmost(metal10a,0,metal1Via0) }
        metal10c { touchingatmost(metal10a,0,metal1Via1) }
        metal10d { touchingexact(metal10a,1,metal1Via0) }
        metal10e { touchingexact(metal10a,1,metal1Via1) }
        metal1Island { 
          (metal10b&(metal10c|metal10e))|(metal10c&(metal10b|metal10d)) }
        via0 { via0&!metal1Island }
        metal1 { metal1&!metal1Island }
        via1 { via1&!metal1Island }
      ]
      remove_layers [ via00  metal10  via10  metal10a  metal1Via0  metal1Via1  
        metal10b  metal10c  metal10d  metal10e  metal1Island  contactOld ]
    }
    devices {
      new_layers [
        device { vpoly&(pdiff|ndiff) }
      ]
    }
    removedevice {
      remove_layers { device }
    }
  }
  compaction {
    passes {
      firstpass { Y }
      nr { 2 }
      last { YES }
    }
    engine { SC }
    mode { FULL }
    solving {
      size_optimization { YES }
      bottom_up { NO }
      mode { NORMAL }
    }
    scanning {
      expand_distance { 2.0 }
    }
    overconstraints {
      priority {
        pitch { 200 }
        polypitch { 190 }
        metal1pitch { 180 }
        lvs { 100 }
        topology { 99 }
        boundary { 96 }
        niceoc { 95 }
        design_rules { 90 }
        glue_rules { 90 }
        abutment { 90 }
        wuc [
          * { 90 }
        ]
        symmetry { 80 }
        alignment { 80 }
        close { 80 }
        far { 80 }
        nicetohave { -10 }
      }
      number_to_report { 1000000 }
    }
    wlo {
      enable { YES }
    }
    verbose {
      rules { YES }
      messages { YES }
      cputime { YES }
      critical { YES }
    }
  }
  layout {
    type { CIF }
    cif {
      sourcedir { src }
      outputdir { result-fubX_first }
    }
  }
  execute [
    start 
    activatepdb {
      param { reallyuglyworkaround }
    }
    usershell {
      param { "FlatCellsFromFubList.pl dcsdatad" }
      save { tmp0_cif }
    }
    addinfo 
    usershell {
      param { "InflateLevel.pl dcsdatad metal1 poly contact" }
      save { tmp1_cif }
    }
    himanipulatelayers {
      param { split_poly }
      save { split_poly_cif }
    }
    himanipulatelayers {
      param { metal1_to_CN }
      save { metal1_to_CN_cif }
    }
    himanipulatelayers {
      param { redefine_metal1 }
      save { redefine_metal1_cif }
    }
    himanipulatelayers {
      param { remove_contacts }
      save { remove_contacts_cif }
    }
    himanipulatelayers {
      param { clean_metal1 }
      save { clean_metal1_cif }
    }
    himanipulatelayers {
      param { merge_via0 }
      save { merge_via0_cif }
    }
    himanipulatelayers {
      param { pre1265 }
      save { pre1265_cif }
    }
    manipulatelayers {
      param { "deglue clean" }
      save { before_texts_removal_cif }
    }
    usershell {
      param { "rmtxt.csh in/${fub}.cif" }
    }
    manipulatelayers {
      param { devices }
    }
    deorientcell {
      save { symlib }
    }
    compactcells 
    stop 
  ]
  job {
    input { dcsdatad }
    verbose {
      messages { YES }
    }
    run_directory { work-fubX_first }
  }
  advancedmacros 
  gui_status {
    outputfile [
      MIGRATE.log {
        text { "Migrate log file" }
        type { TXT }
        class { Messages }
      }
      "tmp0_cif/*" {
        text { out/dcsdatad.cif }
        type { CIF }
        class {
          Saved_results { tmp0_cif }
        }
      }
      "tmp1_cif/*" {
        text { out/dcsdatad.cif }
        type { CIF }
        class {
          Saved_results { tmp1_cif }
        }
      }
      "split_poly_cif/*" {
        text { out/dcsdatad.cif }
        type { CIF }
        class {
          Saved_results { split_poly_cif }
        }
      }
      "metal1_to_CN_cif/*" {
        text { out/dcsdatad.cif }
        type { CIF }
        class {
          Saved_results { metal1_to_CN_cif }
        }
      }
      "redefine_metal1_cif/*" {
        text { out/dcsdatad.cif }
        type { CIF }
        class {
          Saved_results { redefine_metal1_cif }
        }
      }
      "remove_contacts_cif/*" {
        text { out/dcsdatad.cif }
        type { CIF }
        class {
          Saved_results { remove_contacts_cif }
        }
      }
      "clean_metal1_cif/*" {
        text { out/dcsdatad.cif }
        type { CIF }
        class {
          Saved_results { clean_metal1_cif }
        }
      }
      "merge_via0_cif/*" {
        text { out/dcsdatad.cif }
        type { CIF }
        class {
          Saved_results { merge_via0_cif }
        }
      }
      "pre1265_cif/*" {
        text { out/dcsdatad.cif }
        type { CIF }
        class {
          Saved_results { pre1265_cif }
        }
      }
      "before_texts_removal_cif/*" {
        text { out/dcsdatad.cif }
        type { CIF }
        class {
          Saved_results { before_texts_removal_cif }
        }
      }
      "symlib/*" {
        text { out/dcsdatad.cif }
        type { CIF }
        class {
          Saved_results { symlib }
        }
      }
    ]
  }

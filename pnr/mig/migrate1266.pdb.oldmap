      wm1Y_exact {
        rule { width }
        toplevel_only { YES }
        priority { 90 }
        layers [ metal1 ]
        metric { MANHATTAN }
        conditions [
          "passis(ydirection)&(overlap(edge(1),edge(2))>0)&
              ((length(next(edge(1)))<length(edge(1)))&(length(prev(edge(1)))<length(edge(1))))&
              ((length(next(edge(2)))<length(edge(2)))&(length(prev(edge(2)))<length(edge(2))))&
               (distance(edge(1),edge(2))<=0.33)" {
            value {
              exact { 0.165 }
            }
          }

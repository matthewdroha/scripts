use v5.26.1;
use strict;
use warnings;
use English;
use IPC::Open3;
use IO::File;
use Test::More;


plan tests => 4;

ok( sum(1, 1)    == 2,  '1+1');
ok( sum(2, 2)    == 4,  '2+2');
ok( sum(2, 2, 2) == 6,  '2+2+2');
is( sum(1, 1), 3, '1+1 is');
cmp_ok( sum(1, 1), '==',  3, '1+1 cmp_ok');


sub sum {
  my $arg1 = shift;
  my $arg2 = shift;

  return $arg1 + $arg2;
}
